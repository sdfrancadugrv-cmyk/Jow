generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Clientes do Jow
model Client {
  id               String   @id @default(cuid())
  email            String?  @unique
  password         String?
  phone            String?  @unique
  name             String
  stripeCustomerId String?  @unique
  subscriptionId   String?
  status           String   @default("inactive") // active | inactive | cancelled
  plan             String   @default("basic")
  planExpiresAt    DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  devices          Device[]
}

// Dispositivos registrados (máx 2 por cliente)
model Device {
  id        String   @id @default(cuid())
  clientId  String
  token     String   @unique
  name      String   @default("Dispositivo")
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Memória de cada cliente
model Memory {
  id        String   @id @default(cuid())
  clientId  String   @default("owner")
  type      String
  content   String
  period    String?
  msgCount  Int      @default(0)
  createdAt DateTime @default(now())
}

// Histórico de conversas
model Conversation {
  id        String    @id @default(cuid())
  clientId  String    @default("owner")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  agentsUsed     String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId String
}

// Agentes de WhatsApp
model WhatsappAgent {
  id           String   @id @default(cuid())
  clientId     String
  instanceId   String   // Z-API instance ID
  token        String   // Z-API token
  phone        String   // número do WhatsApp
  name         String   // nome do agente
  personality  String   // prompt de personalidade
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  conversations WhatsappConversation[]
}

// Histórico de conversa por contato no WhatsApp
model WhatsappConversation {
  id        String   @id @default(cuid())
  agentId   String
  contact   String   // número do contato
  messages         Json     @default("[]")
  processedIds     Json     @default("[]")
  // Buffer de debounce: agrupa msgs rápidas antes de responder
  pendingMessages  Json     @default("[]")  // msgs aguardando processamento
  pendingMsgIds    Json     @default("[]")  // IDs no buffer (dedup)
  bufferUpdatedAt  DateTime?               // última atualização do buffer
  bufferVersion    String   @default("")   // lock otimista anti-duplicação
  bufferIsFirst    Boolean  @default(false) // primeiro contato do dia desta sessão
  humanMode        Boolean  @default(false) // humano assumiu — bot pausado
  updatedAt        DateTime @updatedAt
  agent     WhatsappAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, contact])
}

// ─── KADOSH SERVIÇOS LOCAIS ───────────────────────────────────────────────────

model ServiceProvider {
  id               String   @id @default(cuid())
  email            String?  @unique
  password         String?
  name             String
  phone            String?  @unique
  googleId         String?  @unique
  facebookId       String?  @unique
  authProvider     String   @default("email") // email | google | facebook | phone
  serviceType      String?
  dailyRate        Float?
  lat              Float?
  lng              Float?
  city             String?
  rating           Float    @default(5.0)
  reviewCount      Int      @default(0)
  stripeCustomerId String?  @unique
  subscriptionId   String?
  status           String   @default("inactive")
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  bids             Bid[]
  reviews          ServiceReview[]
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model ServiceRequest {
  id            String   @id @default(cuid())
  clientName    String
  clientPhone   String
  clientLat     Float
  clientLng     Float
  serviceType   String
  description   String?
  scheduledDate String
  status        String   @default("open")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bids          Bid[]
  reviews       ServiceReview[]
}

model Bid {
  id         String   @id @default(cuid())
  requestId  String
  providerId String
  price      Float
  status     String   @default("active")
  createdAt  DateTime @default(now())
  request    ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  review     ServiceReview?

  @@unique([requestId, providerId])
}

model ServiceReview {
  id              String   @id @default(cuid())
  requestId       String
  bidId           String   @unique
  providerId      String
  clientPhone     String
  providerRating  Float
  providerComment String?
  clientRating    Float
  clientComment   String?
  createdAt       DateTime @default(now())
  request         ServiceRequest  @relation(fields: [requestId], references: [id])
  bid             Bid             @relation(fields: [bidId], references: [id])
  provider        ServiceProvider @relation(fields: [providerId], references: [id])
}
