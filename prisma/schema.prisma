generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id               String    @id @default(cuid())
  email            String?   @unique
  password         String?
  phone            String?   @unique
  name             String
  stripeCustomerId String?   @unique
  subscriptionId   String?
  status           String    @default("inactive")
  plan             String    @default("basic")
  isAdmin          Boolean   @default(false)
  planExpiresAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  devices          Device[]
}

model Device {
  id        String   @id @default(cuid())
  clientId  String
  token     String   @unique
  name      String   @default("Dispositivo")
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Memory {
  id        String   @id @default(cuid())
  clientId  String   @default("owner")
  type      String
  content   String
  period    String?
  msgCount  Int      @default(0)
  createdAt DateTime @default(now())
}

model Conversation {
  id        String    @id @default(cuid())
  clientId  String    @default("owner")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  agentsUsed     String?
  createdAt      DateTime     @default(now())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model WhatsappAgent {
  id             String                 @id @default(cuid())
  clientId       String
  instanceId     String
  token          String
  phone          String
  name           String
  personality    String
  followupRules  Json                   @default("[]")
  mediaLibrary   Json                   @default("[]")
  active         Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  conversations  WhatsappConversation[]
}

model WhatsappConversation {
  id              String        @id @default(cuid())
  agentId         String
  contact         String
  messages        Json          @default("[]")
  processedIds    Json          @default("[]")
  pendingMessages Json          @default("[]")
  pendingMsgIds   Json          @default("[]")
  bufferUpdatedAt DateTime?
  bufferVersion   String        @default("")
  bufferIsFirst   Boolean       @default(false)
  humanMode       Boolean       @default(false)
  updatedAt       DateTime      @updatedAt
  agent           WhatsappAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, contact])
}

model ServiceProvider {
  id               String          @id @default(cuid())
  email            String?         @unique
  password         String?
  name             String
  phone            String?         @unique
  googleId         String?         @unique
  facebookId       String?         @unique
  authProvider     String          @default("email")
  serviceType      String?
  foto             String?
  dailyRate        Float?
  lat              Float?
  lng              Float?
  city             String?
  rating           Float           @default(5.0)
  reviewCount      Int             @default(0)
  stripeCustomerId String?         @unique
  subscriptionId   String?
  status           String          @default("inactive")
  expiresAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  bids             Bid[]
  reviews          ServiceReview[]
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model ServiceRequest {
  id            String          @id @default(cuid())
  clientName    String
  clientPhone   String
  clientLat     Float
  clientLng     Float
  serviceType   String
  description   String?
  scheduledDate String
  status        String          @default("open")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bids          Bid[]
  reviews       ServiceReview[]
}

model Bid {
  id         String          @id @default(cuid())
  requestId  String
  providerId String
  price      Float
  status     String          @default("active")
  createdAt  DateTime        @default(now())
  provider   ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  request    ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  review     ServiceReview?

  @@unique([requestId, providerId])
}

model ProdutoVendedor {
  id                String   @id @default(cuid())
  clientId          String
  slug              String   @unique
  nome              String
  destaques         String
  imageLinks        String[]
  videoLinks        String[]
  salesLink         String
  preco             String
  estrutura         Json
  template          String   @default("produto")
  modalidadeVenda   String   @default("link")
  whatsappContato   String?
  pixKey            String?
  opcoes            Json?
  permitirAfiliados Boolean  @default(false)
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientId])
}

model Afiliado {
  id        String          @id @default(cuid())
  slug      String
  nome      String
  whatsapp  String
  codigo    String          @unique
  saldo     Float           @default(0)
  createdAt DateTime        @default(now())
  saques    SaqueAfiliado[]
  vendas    VendaAfiliado[]

  @@index([slug])
}

model VendaAfiliado {
  id           String   @id @default(cuid())
  afiliadoId   String
  produtoSlug  String
  clientePhone String
  valorPago    Float
  comissao     Float    @default(30)
  paymentId    String?
  status       String   @default("paga")
  createdAt    DateTime @default(now())
  afiliado     Afiliado @relation(fields: [afiliadoId], references: [id], onDelete: Cascade)

  @@index([afiliadoId])
}

model SaqueAfiliado {
  id         String   @id @default(cuid())
  afiliadoId String
  valor      Float
  pixKey     String
  status     String   @default("pendente")
  createdAt  DateTime @default(now())
  afiliado   Afiliado @relation(fields: [afiliadoId], references: [id], onDelete: Cascade)

  @@index([afiliadoId])
}

model PedidoInstalacao {
  id          String   @id @default(cuid())
  produtoSlug String
  nome        String
  telefone    String
  endereco    String
  valor       String
  opcaoNome   String?
  comissao    Float    @default(0)
  status      String   @default("aguardando")
  afiliadoId  String?
  obs         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([produtoSlug])
  @@index([status])
}

model ProdutoShop {
  id                 String                  @id @default(cuid())
  slug               String                  @unique
  nome               String
  descricao          String
  promptVendas       String
  fotos              String[]
  videos             String[]
  fotosResultados    String[]
  linkFonte          String
  custoCompra        Float
  prazoEntrega       String
  precoVenda         Float
  precoComInstalacao Float?
  comissaoPorc       Float                   @default(10)
  tipoVenda          String                  @default("pix")
  ativo              Boolean                 @default(true)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  cliques            CliqueShop[]
  solicitacoes       SolicitacaoInstalacao[]
  vendas             VendaShop[]

  @@index([ativo])
}

model SolicitacaoInstalacao {
  id        String      @id @default(cuid())
  produtoId String
  nome      String
  telefone  String
  cep       String
  cidade    String
  estado    String
  endereco  String
  status    String      @default("pendente")
  createdAt DateTime    @default(now())
  produto   ProdutoShop @relation(fields: [produtoId], references: [id])

  @@index([produtoId])
}

model AfiliadoShop {
  id        String       @id @default(cuid())
  nome      String
  whatsapp  String
  email     String?
  codigo    String       @unique
  saldo     Float        @default(0)
  ativo     Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  cliques   CliqueShop[]
  saques    SaqueShop[]
  vendas    VendaShop[]
}

model VendaShop {
  id              String        @id @default(cuid())
  produtoId       String
  afiliadoId      String?
  nomeCliente     String
  telefoneCliente String        @default("")
  enderecoCliente String        @default("")
  whatsappCliente String        @default("")
  valorPago       Float
  comissaoValor   Float         @default(0)
  paymentId       String?
  status          String        @default("pendente")
  createdAt       DateTime      @default(now())
  afiliado        AfiliadoShop? @relation(fields: [afiliadoId], references: [id])
  produto         ProdutoShop   @relation(fields: [produtoId], references: [id])

  @@index([afiliadoId])
  @@index([produtoId])
}

model SaqueShop {
  id         String       @id @default(cuid())
  afiliadoId String
  valor      Float
  pixKey     String
  status     String       @default("pendente")
  createdAt  DateTime     @default(now())
  afiliado   AfiliadoShop @relation(fields: [afiliadoId], references: [id])

  @@index([afiliadoId])
}

model CliqueShop {
  id         String        @id @default(cuid())
  afiliadoId String?
  produtoId  String
  ip         String?
  tipo       String        @default("afiliado")
  createdAt  DateTime      @default(now())
  afiliado   AfiliadoShop? @relation(fields: [afiliadoId], references: [id])
  produto    ProdutoShop   @relation(fields: [produtoId], references: [id])

  @@index([afiliadoId])
  @@index([produtoId])
}

model ValvulaOrder {
  id         String   @id @default(cuid())
  nome       String
  telefone   String
  endereco   String
  opcao      String   // "self" | "tecnico"
  valor      Float
  paymentId  String?
  status     String   @default("pendente") // pendente | pago | enviado | cancelado
  obs        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
}

model ConfigProfessor {
  id        String   @id @default(cuid())
  clientId  String   @unique
  plano     String
  linguas   String[]
  concursos String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AulaProfessor {
  id        String   @id @default(cuid())
  clientId  String
  materia   String
  resumo    String?
  mensagens Json
  plano     String   @default("professor-start")
  createdAt DateTime @default(now())

  @@index([clientId])
}

model AvaliacaoProfessor {
  id        String   @id @default(cuid())
  clientId  String
  materias  String[]
  formato   String
  resultado String?
  nota      String?
  mensagens Json
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ServiceReview {
  id              String          @id @default(cuid())
  requestId       String
  bidId           String          @unique
  providerId      String
  clientPhone     String
  providerRating  Float
  providerComment String?
  clientRating    Float
  clientComment   String?
  createdAt       DateTime        @default(now())
  bid             Bid             @relation(fields: [bidId], references: [id])
  provider        ServiceProvider @relation(fields: [providerId], references: [id])
  request         ServiceRequest  @relation(fields: [requestId], references: [id])
}
